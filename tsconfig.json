{
  "compilerOptions": {
    "module": "ESNext", // 打包模块类型为 ESNext
    "declaration": false, // 不生成类型声明文件（.d.ts）
    "noImplicitAny": true, // 允许变量/参数不标注类型时默认为 any 类型
    "removeComments": true, // 编译时移除代码中的注释
    "moduleResolution": "node", // 按照 Node.js 的模块解析规则查找模块
    "esModuleInterop": true, // 兼容 ES6 和 CommonJS 模块的互操作
    "jsx": "preserve", // 保留 JSX 语法不进行转换（通常用于 React 等框架，由其他工具如 babel 处理）
    "noLib": false, // 不排除 TypeScript 内置的库文件（如 lib.es6.d.ts）
    "target": "es6", // 编译目标为 ES6 版本
    "sourceMap": true, // 生成 sourceMap 文件，方便调试
    "lib": [ // 编译时包含的库文件
      "ESNext",
      "DOM"
    ],
    "allowSyntheticDefaultImports": true, // 允许从没有默认导出的模块中导入默认值
    "experimentalDecorators": true, // 启用装饰器语法（实验性特性）
    "forceConsistentCasingInFileNames": true, // 强制文件名大小写一致（避免跨平台问题）
    "resolveJsonModule": true, // 允许导入 .json 模块
    "strict": true, // 启用所有严格的类型检查选项（如 strictNullChecks、strictFunctionTypes 等）
    "skipLibCheck": true // 跳过对第三方库（如 node_modules 中的）类型声明文件的检查
  },
  "exclude": [ // 编译时排除的文件/目录
    "node_modules",
    "**/__tests__",
    "dist"
  ]
}